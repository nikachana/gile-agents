{
  "$id": "contracts/prose_evaluation_case_v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProseEvaluationCaseV1",
  "description": "Offline evaluation case for prose_drafting_v1.",
  "type": "object",
  "required": ["case_id", "scope", "inputs", "evaluation_result"],
  "properties": {
    "case_id": {
      "type": "string",
      "description": "Stable identifier for this evaluation case."
    },
    "scope": {
      "type": "string",
      "enum": ["prose_drafting_v1"],
      "description": "Scope tag for the evaluation case, currently only 'prose_drafting_v1' is supported."
    },
    "inputs": {
      "type": "object",
      "required": ["task_context", "planner_output", "final_prose_output"],
      "properties": {
        "task_context": {
          "type": "object",
          "description": "Opaque task setup and instructions."
        },
        "planner_output": {
          "type": "object",
          "description": "Planner artifact used to drive drafting."
        },
        "final_prose_output": {
          "type": "object",
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "description": "Final prose text chosen for evaluation."
            }
          },
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "description": "Optional extra metadata about inputs."
        }
      },
      "additionalProperties": true
    },
    "evaluation_result": {
      "type": "object",
      "required": ["dimension_ratings", "overall_result", "provenance"],
      "properties": {
        "dimension_ratings": {
          "type": "object",
          "description": "Ratings for each evaluation dimension.",
          "required": [
            "structural_compliance",
            "semantic_fidelity",
            "prose_quality"
          ],
          "properties": {
            "structural_compliance": {
              "type": "string",
              "enum": ["strong", "acceptable", "weak", "failed"]
            },
            "semantic_fidelity": {
              "type": "string",
              "enum": ["strong", "acceptable", "weak", "failed"]
            },
            "prose_quality": {
              "type": "string",
              "enum": ["strong", "acceptable", "weak", "failed"]
            }
          },
          "additionalProperties": false
        },
        "overall_result": {
          "type": "string",
          "enum": ["acceptable", "unacceptable"]
        },
        "provenance": {
          "type": "string",
          "enum": ["model_assisted", "human_reviewed", "both"]
        },
        "metadata": {
          "type": "object",
          "description": "Optional extra metadata about evaluation results."
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "description": "Optional top-level metadata about the case."
    }
  },
  "additionalProperties": true
}

